---
// src/pages/contact.astro
// Source: Figma node 122:1109 — Contact Page
import BaseLayout from '../layouts/BaseLayout.astro';
import NavBar from '../components/NavBar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Contact — The Mod Squad Team"
  description="Get in touch with The Mod Squad Team. Start your modular construction project today."
>
  <NavBar activePage="contact" />
  <main>

    <section class="contact">
      <div class="contact__inner">

        <!-- Left: Form -->
        <div class="contact__form-col">
          <div class="eyebrow">
            <span class="eyebrow-line eyebrow-line--blue"></span>
            <span class="eyebrow-text eyebrow-text--blue">Get in Touch</span>
          </div>
          <h1 class="contact__title">Start Your Project</h1>
          <p class="contact__desc">We'd love to hear from you. Reach out and let's discuss what modular can do for your next project.</p>

          <form class="contact-form" action="https://formspree.io/f/mqewdadq" method="POST">
            <div class="contact-form__row">
              <div class="contact-form__field">
                <input type="text" name="name" id="name" placeholder="Full Name*" required class="contact-form__input" />
              </div>
              <div class="contact-form__field">
                <input type="text" name="company" id="company" placeholder="Company" class="contact-form__input" />
              </div>
            </div>
            <div class="contact-form__row">
              <div class="contact-form__field">
                <input type="email" name="email" id="email" placeholder="Email*" required class="contact-form__input" />
              </div>
              <div class="contact-form__field">
                <input type="tel" name="phone" id="phone" placeholder="Phone*" required class="contact-form__input" />
              </div>
            </div>
            <div class="contact-form__field contact-form__field--full">
              <textarea name="message" id="message" placeholder="Tell us about your project — timeline, location, project type..." rows="5" class="contact-form__textarea"></textarea>
            </div>

            <div class="contact-form__interests">
              <p class="contact-form__interests-label">I'm Interested In</p>
              <div class="contact-form__checkboxes">
                <label class="contact-form__check">
                  <input type="checkbox" name="interest" value="factory-design" />
                  <span class="contact-form__check-box"></span>
                  Factory Design
                </label>
                <label class="contact-form__check">
                  <input type="checkbox" name="interest" value="consulting" />
                  <span class="contact-form__check-box"></span>
                  Project Consulting
                </label>
                <label class="contact-form__check">
                  <input type="checkbox" name="interest" value="recruitment" />
                  <span class="contact-form__check-box"></span>
                  Workforce Recruitment
                </label>
                <label class="contact-form__check">
                  <input type="checkbox" name="interest" value="feasibility" />
                  <span class="contact-form__check-box"></span>
                  Feasibility Study
                </label>
              </div>
            </div>

            <button type="submit" class="contact-form__submit">Send Message</button>
          </form>
        </div>

        <!-- Right: Image + Info -->
        <div class="contact__info-col">
          <div class="contact__image-wrap">
            <img
              src="/img/projects/Florida Mega Factory.webp"
              alt="Modular construction project"
              class="contact__image"
            />
          </div>

          <div class="contact-info">
            <div class="eyebrow">
              <span class="eyebrow-line"></span>
              <span class="eyebrow-text">Contact Information</span>
            </div>
            <h2 class="contact-info__name">The Mod Squad Team, LLC.</h2>
            <div class="contact-info__divider"></div>

            <div class="contact-info__row">
              <p class="contact-info__meta-label">Phone</p>
              <a href="tel:7276475022" class="contact-info__value">727-647-5022</a>
            </div>

            <div class="contact-info__divider"></div>

            <div class="contact-info__row">
              <p class="contact-info__meta-label">Email</p>
              <a href="mailto:info@themodsquadteam.com" class="contact-info__value contact-info__value--sm">info@themodsquadteam.com</a>
            </div>

            <div class="contact-info__divider"></div>

            <p class="contact-info__note">
              We typically respond within 24 hours. For urgent inquiries, call us directly.
            </p>
          </div>
        </div>

      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
  .contact {
    background: var(--color-surface);
    width: 100%;
    min-height: calc(100vh - 66px - 62px);
  }
  .contact__inner {
    max-width: var(--max-w); margin: 0 auto;
    padding: 70px var(--pad-x);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }

  /* ── Form column ────────────────────── */
  .contact__form-col {
    display: flex; flex-direction: column; gap: 16px;
  }
  .contact__title {
    font-size: var(--font-h1); font-weight: var(--fw-bold);
    color: var(--color-text-dark); line-height: 1;
  }
  .contact__desc {
    font-size: var(--font-body); color: var(--color-text-mid); line-height: 20px;
  }

  .contact-form {
    display: flex; flex-direction: column; gap: 14px;
    margin-top: 8px;
  }
  .contact-form__row {
    display: grid; grid-template-columns: 1fr 1fr; gap: 14px;
  }
  .contact-form__field { display: flex; flex-direction: column; }
  .contact-form__field--full { grid-column: span 2; }

  .contact-form__input,
  .contact-form__textarea {
    background: var(--color-white);
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 0 12px;
    height: 44px;
    font-size: 12px; font-family: var(--font-family);
    color: var(--color-text-dark);
    width: 100%;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .contact-form__input::placeholder,
  .contact-form__textarea::placeholder {
    color: var(--color-text-faint);
  }
  .contact-form__input:focus,
  .contact-form__textarea:focus {
    outline: none;
    border-color: var(--color-blue);
    box-shadow: 0 0 0 3px rgba(30,127,216,0.1);
  }
  .contact-form__textarea {
    height: auto; padding: 12px; resize: vertical;
  }

  /* Checkboxes */
  .contact-form__interests { display: flex; flex-direction: column; gap: 10px; }
  .contact-form__interests-label {
    font-size: 8px; font-weight: var(--fw-medium);
    color: var(--color-text-faint); letter-spacing: 1.5px; text-transform: uppercase;
  }
  .contact-form__checkboxes {
    display: grid; grid-template-columns: 1fr 1fr; gap: 10px 24px;
  }
  .contact-form__check {
    display: flex; align-items: center; gap: 8px;
    font-size: 11px; color: var(--color-text-mid);
    cursor: pointer; user-select: none;
  }
  .contact-form__check input[type="checkbox"] { display: none; }
  .contact-form__check-box {
    width: 16px; height: 16px; flex-shrink: 0;
    background: var(--color-white);
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-sm);
    display: flex; align-items: center; justify-content: center;
    transition: background 0.15s, border-color 0.15s;
  }
  .contact-form__check input:checked + .contact-form__check-box {
    background: var(--color-blue); border-color: var(--color-blue);
  }
  .contact-form__check input:checked + .contact-form__check-box::after {
    content: '';
    width: 8px; height: 5px;
    border-left: 1.5px solid white;
    border-bottom: 1.5px solid white;
    transform: rotate(-45deg) translateY(-1px);
    display: block;
  }

  /* Submit */
  .contact-form__submit {
    display: inline-flex; align-items: center; justify-content: center;
    background: var(--color-blue); color: var(--color-white);
    font-size: 10px; font-weight: var(--fw-bold);
    letter-spacing: 1.2px; text-transform: uppercase;
    width: 200px; height: 44px;
    border: none; border-radius: var(--radius-sm);
    cursor: pointer;
    transition: background 0.15s;
    margin-top: 6px;
  }
  .contact-form__submit:hover { background: #1a6fc0; }

  /* ── Info column ────────────────────── */
  .contact__info-col {
    display: flex; flex-direction: column; gap: 16px;
  }
  .contact__image-wrap {
    border-radius: var(--radius-lg);
    overflow: hidden;
    height: 260px;
    border: 0.5px solid rgba(74,159,224,0.15);
  }
  .contact__image {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }

  .contact-info {
    background: var(--color-navy);
    border-radius: var(--radius-lg);
    padding: 24px;
    display: flex; flex-direction: column; gap: 16px;
  }
  .contact-info__name {
    font-size: 18px; font-weight: var(--fw-bold);
    color: var(--color-white); line-height: 1;
  }
  .contact-info__divider {
    width: 100%; height: 0.5px; background: rgba(255,255,255,0.08);
  }
  .contact-info__row { display: flex; flex-direction: column; gap: 6px; }
  .contact-info__meta-label {
    font-size: 8px; font-weight: var(--fw-medium);
    color: var(--color-text-faint); letter-spacing: 1.5px; text-transform: uppercase;
  }
  .contact-info__value {
    font-size: var(--font-body-lg); font-weight: var(--fw-bold);
    color: var(--color-blue-light); line-height: 1;
    transition: opacity 0.15s;
  }
  .contact-info__value--sm { font-size: var(--font-body); font-weight: var(--fw-regular); }
  .contact-info__value:hover { opacity: 0.8; }
  .contact-info__note {
    font-size: var(--font-body-sm); color: var(--color-text-faint); line-height: 18px;
  }

  /* ── Responsive ─────────────────────── */
  @media (max-width: 1024px) {
    .contact__inner { grid-template-columns: 1fr; gap: 40px; }
  }
  @media (max-width: 768px) {
    .contact__inner { padding: 48px 24px; }
    .contact-form__row { grid-template-columns: 1fr; }
    .contact-form__checkboxes { grid-template-columns: 1fr; }
    .contact-form__submit { width: 100%; }
  }
</style>
