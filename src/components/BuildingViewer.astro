---
// src/components/BuildingViewer.astro
---

<!-- <div class="viewer-wrap">
  <div class="viewer-skeleton" id="viewer-skeleton">
    <div class="viewer-skeleton__spinner"></div>
    <p class="viewer-skeleton__label">Loading 3D model...</p>
  </div> -->

  <model-viewer
    id="building-viewer"
    src="/models/building.glb"
    alt="Modular building 3D model — drag to rotate"
    camera-controls
    auto-rotate
    auto-rotate-delay="1000"
    rotation-per-second="12deg"
    shadow-intensity="1"
    shadow-softness="0.8"
    exposure="1.1"
    environment-image="neutral"
    camera-orbit="-30deg 75deg 120%"
    min-camera-orbit="auto auto 60%"
    max-camera-orbit="auto auto 200%"
    touch-action="pan-y"
  ></model-viewer>

  <div class="viewer-hint" id="viewer-hint">
    <span>↻</span>
    <span>Drag to rotate · Scroll to zoom</span>
  </div>
</div>

<script is:inline type="module" src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js"></script>

<script>
  const viewer   = document.getElementById('building-viewer') as any;
  const skeleton = document.getElementById('viewer-skeleton');
  const hint     = document.getElementById('viewer-hint');

  viewer?.addEventListener('load', () => {
    if (skeleton) skeleton.style.display = 'none';
    setTimeout(() => { if (hint) hint.style.opacity = '0'; }, 4000);
  });

  viewer?.addEventListener('camera-change', () => {
    viewer.autoRotate = false;
    clearTimeout(viewer.__t);
    viewer.__t = setTimeout(() => { viewer.autoRotate = true; }, 3000);
  });
</script>

<style>
  .viewer-wrap {
    position: relative;
    width: 100%; height: 100%;
    min-height: 400px;
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  model-viewer {
    width: 100%; height: 100%;
    min-height: 400px;
    display: block;
    background: transparent;
    --progress-bar-color: transparent;
    --progress-mask: transparent;
  }

  @media (max-width: 1024px) {
    .viewer-wrap { min-height: 340px; }
    model-viewer  { min-height: 340px; }
  }
  @media (max-width: 768px) {
    .viewer-wrap { min-height: 280px; }
    model-viewer  { min-height: 280px; }
  }

  .viewer-skeleton {
    position: absolute; inset: 0; z-index: 2;
    background: linear-gradient(135deg, #122640, #1a3a5c);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 12px;
    border-radius: var(--radius-lg);
  }
  .viewer-skeleton__spinner {
    width: 48px; height: 48px; border-radius: 50%;
    border: 2px solid rgba(74,159,224,0.25);
    border-top-color: var(--color-blue-light);
  }
  .viewer-skeleton__label {
    font-size: var(--font-label);
    font-weight: var(--fw-medium);
    color: var(--color-text-faint);
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .viewer-hint {
    position: absolute; bottom: 16px; left: 50%;
    transform: translateX(-50%);
    display: flex; align-items: center; gap: 6px;
    background: rgba(13,27,46,0.75);
    padding: 6px 14px; border-radius: 20px;
    pointer-events: none;
    transition: opacity 0.6s ease;
    font-size: 9px; font-weight: var(--fw-medium);
    color: rgba(255,255,255,0.65);
    letter-spacing: 1px; text-transform: uppercase;
    white-space: nowrap;
  }
</style>