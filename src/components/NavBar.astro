    <ul class="navbar__links" role="list">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class:list={['navbar__link', { 'navbar__link--active': activePage === link.key }]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <a href="/contact" class="navbar__cta">Contact Us</a>

    <button class="navbar__burger" aria-label="Toggle menu" aria-expanded="false" id="nav-burger">
      <span></span><span></span><span></span>
    </button>
