---
// src/components/Footer.astro
// Source: Figma node 36:693 — Footer
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__inner">

    <!-- Social icons -->
    <div class="footer__social">
      <a href="https://www.linkedin.com/company/the-mod-squad-team/posts/?feedView=all" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="footer__social-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
          <rect x="2" y="9" width="4" height="12"/>
          <circle cx="4" cy="4" r="2"/>
        </svg>
      </a>
      <a href="mailto:info@themodsquadteam.com" aria-label="Email" class="footer__social-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
      </a>
    </div>

    <!-- Copyright -->
    <p class="footer__copy">Copyright &copy; {year} The Mod Squad Team &mdash; All Rights Reserved.</p>

  </div>
</footer>

<style>
  .footer {
    background: var(--color-navy);
    border-top: 0.5px solid rgba(255,255,255,0.06);
    width: 100%;
  }

  .footer__inner {
    max-width: var(--max-w); margin: 0 auto;
    padding: 10px 47px;
    height: 62px;
    display: flex; align-items: center; justify-content: space-between;
  }

  .footer__social {
    display: flex; align-items: center; gap: 16px;
  }
  .footer__social-link {
    color: var(--color-text-faint);
    display: flex; align-items: center;
    transition: color 0.15s;
  }
  .footer__social-link:hover { color: var(--color-white); }

  .footer__copy {
    font-size: 11px;
    font-weight: var(--fw-regular);
    color: var(--color-text-light);
    line-height: 16px;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .footer__inner {
      flex-direction: column; justify-content: center;
      height: auto; padding: 20px 24px; gap: 12px;
    }
    .footer__copy { text-align: center; white-space: normal; }
  }
</style>
