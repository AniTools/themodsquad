---
// src/components/ui/FormInput.astro
// Source: Figma node 10:41 — Form/Input
export interface Props {
  name: string;
  label: string;
  placeholder?: string;
  type?: string;
  required?: boolean;
}
const { name, label, placeholder = '', type = 'text', required = false } = Astro.props;
---

<div class="form-field">
  <label class="form-field__label" for={name}>{label}</label>
  <input
    class="form-input"
    id={name}
    name={name}
    type={type}
    placeholder={placeholder}
    required={required}
    aria-label={label}
  />
</div>

<style>
  .form-field { display: flex; flex-direction: column; gap: 6px; }
  .form-field__label {
    font-size: var(--font-label); font-weight: var(--fw-medium);
    color: var(--color-text-mid); letter-spacing: 1px; text-transform: uppercase;
  }
  .form-input {
    width: 100%; height: 44px; /* Figma node 10:41 */
    background: var(--color-white);
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-md); /* 4px — Figma token --radius-md */
    padding: 0 12px;
    font-family: var(--font-family);
    font-size: 12px; color: var(--color-text-dark);
    transition: border-color 0.15s;
    outline: none;
  }
  .form-input::placeholder { color: var(--color-text-faint); }
  .form-input:focus { border-color: var(--color-blue); }
</style>
