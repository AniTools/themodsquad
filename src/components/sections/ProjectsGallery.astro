---
// src/components/sections/ProjectsGallery.astro
// Source: Figma node 106:386 — ProjectCard/Featured
// Fix: title 22px Heading/2, gradient from-23% navy 80% opacity

const projects = [
  { anchor: 'florida-mega-factory', tag: 'Factory Design · Florida',  title: 'Florida Mega Factory',   meta: 'Full-facility modular manufacturing plant', category: 'factory', img: '/img/projects/Florida Mega Factory.webp', featured: true },
  { anchor: 'tutemok',              tag: 'Modular Building · AZ',     title: 'Tutemok',                 meta: 'Architectural design · BIM compliant',       category: 'modular', img: '/img/projects/Tutemok.webp' },
  { anchor: 'factory-one',          tag: 'Factory Design',            title: 'Factory One',             meta: 'Plant layout · lean manufacturing',          category: 'factory', img: '/img/projects/Factory One.webp' },
  { anchor: 'factory-two',          tag: 'Factory Design · Sketch',   title: 'Factory Two',             meta: 'Concept to construction docs',               category: 'factory', img: '/img/projects/Factory Two.webp' },
  { anchor: 'on-site-preparation',  tag: 'Site Development',          title: 'On-site Preparation',     meta: 'Grading · utilities · foundation',           category: 'site',    img: '/img/projects/On-Site.webp' },
];
const filters = [
  { label: 'All Projects',      key: 'all'    },
  { label: 'Factory Design',    key: 'factory' },
  { label: 'Modular Buildings', key: 'modular' },
  { label: 'Site Development',  key: 'site'    },
];
---

<section class="projects-gallery">
  <div class="projects-gallery__inner">
    <div class="projects-gallery__header">
      <div class="eyebrow">
        <span class="eyebrow-line"></span>
        <span class="eyebrow-text">Our Work</span>
      </div>
      <h2 class="projects-gallery__title">
        Projects That<br>
        <span class="projects-gallery__title-accent">Prove the Point.</span>
      </h2>
      <p class="projects-gallery__desc">
        Real builds. Real timelines. From factory floor to full-site delivery — every project is a module in our track record.
      </p>
    </div>

    <div class="projects-gallery__filters" role="group" aria-label="Filter projects">
      {filters.map((f, i) => (
        <button class:list={['filter-btn', { 'filter-btn--active': i === 0 }]} data-filter={f.key}>
          {f.label}
        </button>
      ))}
    </div>

    <div class="projects-gallery__grid" id="projects-grid">
      {projects.map(project => (
        <a
          href={`/projects#${project.anchor}`}
          class:list={['project-card', { 'project-card--featured': project.featured }]}
          data-category={project.category}
        >
          <div class="project-card__img" style={`background-image: url('${project.img}')`} aria-hidden="true"></div>
          <div class="project-card__overlay">
            <div class="project-card__body">
              <span class="project-card__tag">{project.tag}</span>
              <h3 class:list={['project-card__title', { 'project-card__title--featured': project.featured }]}>
                {project.title}
              </h3>
              <p class="project-card__meta">{project.meta}</p>
            </div>
          </div>
          <div class="project-card__arrow" aria-hidden="true">↗</div>
        </a>
      ))}
    </div>

    <div class="projects-gallery__footer">
      <span class="projects-gallery__count">Showing <strong id="project-count">5</strong> of 12 projects</span>
      <a href="/projects" class="btn-ghost btn-ghost--small">View All Projects →</a>
    </div>
  </div>
</section>

<style>
  .projects-gallery { background: var(--color-navy); border-top: 0.5px solid rgba(255,255,255,0.06); width: 100%; }
  .projects-gallery__inner { max-width: var(--max-w); margin: 0 auto; padding: 70px var(--pad-x); display: flex; flex-direction: column; gap: 28px; }

  .projects-gallery__header { display: flex; flex-direction: column; gap: 12px; max-width: 600px; }
  .projects-gallery__title  { font-size: var(--font-h1); font-weight: var(--fw-bold); color: var(--color-white); line-height: 1.15; }
  .projects-gallery__title-accent { color: var(--color-blue-light); }
  .projects-gallery__desc   { font-size: var(--font-body); color: var(--color-text-faint); line-height: 20px; max-width: 560px; }

  .projects-gallery__filters { display: flex; gap: var(--spacing-sm); flex-wrap: wrap; }
  .filter-btn {
    font-size: 8px; font-weight: var(--fw-bold); letter-spacing: 1.5px; text-transform: uppercase;
    color: var(--color-text-light); background: transparent;
    border: 0.5px solid rgba(255,255,255,0.12); border-radius: var(--radius-sm);
    padding: 0 14px; height: 28px; cursor: pointer; transition: all 0.15s;
  }
  .filter-btn:hover { border-color: var(--color-blue); color: var(--color-blue-light); }
  .filter-btn--active { background: var(--color-blue); color: var(--color-white); border-color: var(--color-blue); }

  .projects-gallery__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: 178px 148px;
    gap: 10px;
  }
  .project-card { position: relative; border-radius: var(--radius-lg); overflow: hidden; display: block; background: #122640; border: 1px solid rgba(208,216,232,0.1); }
  .project-card--featured { grid-column: span 2; }

  .project-card__img {
    position: absolute; inset: 0;
    background-size: cover;
    background-position: center;
    background-color: #122640;
    transition: transform 0.4s ease;
  }
  .project-card:hover .project-card__img { transform: scale(1.04); }

  .project-card__overlay {
    position: absolute; inset: 0;
    /* Figma gradient: from 23.3% rgba(13,27,46,0.8) → to 73.4% rgba(102,102,102,0.05) */
    background: linear-gradient(to top, rgba(13,27,46,0.8) 23.3%, rgba(102,102,102,0.05) 73.4%);
    display: flex; align-items: flex-end; padding: var(--spacing-md);
  }
  .project-card__body { display: flex; flex-direction: column; gap: 4px; }

  .project-card__tag {
    display: inline-block;
    font-size: 7px; font-weight: var(--fw-medium); color: var(--color-blue-light);
    background: rgba(30,127,216,0.18);
    letter-spacing: 1.5px; text-transform: uppercase;
    padding: 4px 8px; border-radius: 9px; width: fit-content;
  }
  .project-card__title       { font-size: var(--font-body); font-weight: var(--fw-bold); color: var(--color-white); }
  .project-card__title--featured { font-size: var(--font-h2); } /* Heading/2 per Figma node 106:379 */
  .project-card__meta        { font-size: var(--font-body-sm); color: var(--color-text-faint); }

  .project-card__arrow {
    position: absolute; top: 12px; right: 12px;
    width: 28px; height: 28px; border-radius: 14px;
    background: var(--color-blue); color: var(--color-white);
    font-size: 11px; display: flex; align-items: center; justify-content: center;
    opacity: 0; transition: opacity 0.2s;
  }
  .project-card:hover .project-card__arrow { opacity: 1; }

  .projects-gallery__footer { display: flex; align-items: center; justify-content: space-between; padding-top: 16px; border-top: 0.5px solid rgba(255,255,255,0.06); }
  .projects-gallery__count  { font-size: 10px; color: var(--color-text-faint); }
  .projects-gallery__count strong { color: var(--color-blue-light); }

  @media (max-width: 1024px) { .projects-gallery__grid { grid-template-columns: repeat(2, 1fr); grid-template-rows: auto; } .project-card--featured { grid-column: span 2; height: 200px; } .project-card { height: 150px; } }
  @media (max-width: 768px)  { .projects-gallery__inner { padding: 48px 24px; } .projects-gallery__grid { grid-template-columns: 1fr; grid-template-rows: auto; } .project-card--featured, .project-card { grid-column: span 1; height: 160px; } }
</style>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.project-card');
  const countEl = document.getElementById('project-count');
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;
      filterBtns.forEach(b => b.classList.remove('filter-btn--active'));
      btn.classList.add('filter-btn--active');
      let visible = 0;
      cards.forEach(card => {
        const match = filter === 'all' || card.dataset.category === filter;
        card.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      if (countEl) countEl.textContent = String(visible);
    });
  });
</script>
